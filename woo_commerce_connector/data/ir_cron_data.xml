<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron for Auto Import Orders -->
        <record id="ir_cron_woo_import_orders" model="ir.cron">
            <field name="name">WooCommerce: Auto Import Orders</field>
            <field name="model_id" ref="model_woo_backend"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_import_orders()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="False"/>
        </record>

        <!-- Cron for Auto Export Stock -->
        <record id="ir_cron_woo_export_stock" model="ir.cron">
            <field name="name">WooCommerce: Auto Export Stock</field>
            <field name="model_id" ref="model_woo_backend"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_export_stock()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
