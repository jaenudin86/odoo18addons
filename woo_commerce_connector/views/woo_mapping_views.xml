<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category Mapping -->
    <record id="view_woo_product_category_mapping_tree" model="ir.ui.view">
        <field name="name">woo.product.category.mapping.tree</field>
        <field name="model">woo.product.category.mapping</field>
        <field name="arch" type="xml">
            <list>
                <field name="backend_id"/>
                <field name="woo_id"/>
                <field name="odoo_id"/>
                <field name="last_sync_date"/>
            </list>
        </field>
    </record>

    <record id="action_woo_product_category_mapping" model="ir.actions.act_window">
        <field name="name">Category Mappings</field>
        <field name="res_model">woo.product.category.mapping</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Attribute Mapping -->
    <record id="view_woo_product_attribute_mapping_tree" model="ir.ui.view">
        <field name="name">woo.product.attribute.mapping.tree</field>
        <field name="model">woo.product.attribute.mapping</field>
        <field name="arch" type="xml">
            <list>
                <field name="backend_id"/>
                <field name="woo_id"/>
                <field name="odoo_id"/>
                <field name="last_sync_date"/>
            </list>
        </field>
    </record>

    <record id="action_woo_product_attribute_mapping" model="ir.actions.act_window">
        <field name="name">Attribute Mappings</field>
        <field name="res_model">woo.product.attribute.mapping</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Product Template Mapping -->
    <record id="view_woo_product_template_mapping_tree" model="ir.ui.view">
        <field name="name">woo.product.template.mapping.tree</field>
        <field name="model">woo.product.template.mapping</field>
        <field name="arch" type="xml">
            <list>
                <field name="backend_id"/>
                <field name="woo_id"/>
                <field name="odoo_id"/>
                <field name="last_sync_date"/>
            </list>
        </field>
    </record>

    <record id="action_woo_product_template_mapping" model="ir.actions.act_window">
        <field name="name">Product Mappings</field>
        <field name="res_model">woo.product.template.mapping</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Product Product (Variant) Mapping -->
    <record id="view_woo_product_product_mapping_tree" model="ir.ui.view">
        <field name="name">woo.product.product.mapping.tree</field>
        <field name="model">woo.product.product.mapping</field>
        <field name="arch" type="xml">
            <list>
                <field name="backend_id"/>
                <field name="woo_id"/>
                <field name="odoo_id"/>
                <field name="last_sync_date"/>
            </list>
        </field>
    </record>

    <record id="action_woo_product_product_mapping" model="ir.actions.act_window">
        <field name="name">Variant Mappings</field>
        <field name="res_model">woo.product.product.mapping</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
