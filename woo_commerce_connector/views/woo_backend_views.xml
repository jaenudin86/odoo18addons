<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_woo_backend_tree" model="ir.ui.view">
        <field name="name">woo.backend.tree</field>
        <field name="model">woo.backend</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="woo_url"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'confirmed'" 
                       decoration-danger="state == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_woo_backend_form" model="ir.ui.view">
        <field name="name">woo.backend.form</field>
        <field name="model">woo.backend</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="btn-primary" invisible="state == 'confirmed'"/>
                    <button name="action_test_connection" string="Reconnect" type="object" invisible="state != 'confirmed'"/>
                    <button name="action_register_webhooks" string="Register Webhooks" type="object" class="btn-warning" invisible="state != 'confirmed'"/>
                    <button name="action_open_operations" string="Perform Operations" type="object" class="btn-info" invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Instance Name (e.g. My Woo Store)"/>
                        </h1>
                    </div>
                    <group>
                        <group string="API Credentials">
                            <field name="woo_url" placeholder="https://yourstore.com"/>
                            <field name="woo_consumer_key"/>
                            <field name="woo_consumer_secret" password="True"/>
                        </group>
                        <group string="Statistics">
                            <field name="total_products" readonly="1"/>
                            <field name="total_orders" readonly="1"/>
                            <field name="total_revenue" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Automation">
                            <group string="Scheduled Actions">
                                <field name="auto_import_products"/>
                                <field name="auto_import_orders"/>
                                <field name="auto_export_stock"/>
                            </group>
                        </page>
                        <group string="Defaults">
                            <field name="warehouse_id"/>
                            <field name="pricelist_id"/>
                            <field name="sales_team_id"/>
                        </group>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_woo_backend" model="ir.actions.act_window">
        <field name="name">WooCommerce Instances</field>
        <field name="res_model">woo.backend</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
