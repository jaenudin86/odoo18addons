<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_bill_project" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.bill.project</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <!-- <xpath expr="//div[@id='account']" position="after"> -->
                <xpath expr="//setting[@id='track_costs_revenues']" position="after">
                    <div id="account_bill_project">
                        <h2>Bill Project Approval</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="director_approval_limit"/>
                                    <div class="text-muted">
                                        Tagihan di atas nilai ini akan membutuhkan persetujuan Direktur Keuangan.
                                    </div>
                                    <div class="content-group mt8">
                                        <div class="row">
                                            <label string="Batas Nilai (Rp)" class="col-lg-4 o_light_label"/>
                                            <field name="director_approval_limit" class="col-lg-4"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
