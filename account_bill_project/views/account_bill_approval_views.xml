<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List view untuk approval log -->
        <record id="view_account_bill_approval_tree" model="ir.ui.view">
            <field name="name">account.bill.approval.tree</field>
            <field name="model">account.bill.approval</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="create_date" string="Tanggal"/>
                    <field name="move_id" string="Tagihan"/>
                    <field name="user_id" string="User"/>
                    <field name="state" string="Status"
                           decoration-success="state == 'approved'"
                           decoration-danger="state == 'rejected'"
                           decoration-warning="state == 'waiting'"/>
                    <field name="note" string="Catatan"/>
                </tree>
            </field>
        </record>

        <!-- Action: Tagihan Menunggu Persetujuan -->
        <record id="action_bill_waiting_approval" model="ir.actions.act_window">
            <field name="name">Tagihan Menunggu Persetujuan</field>
            <field name="res_model">account.move</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('move_type', '=', 'in_invoice'), ('x_approval_state', '=', 'waiting')]</field>
            <field name="context">{'default_move_type': 'in_invoice'}</field>
        </record>

        <!-- Menu item di bawah Accounting > Vendors -->
        <menuitem id="menu_bill_waiting_approval"
                  name="Menunggu Persetujuan"
                  parent="account.menu_finance_payables"
                  action="action_bill_waiting_approval"
                  sequence="15"
                  groups="account_bill_project.group_bill_finance_manager"/>

    </data>
</odoo>
