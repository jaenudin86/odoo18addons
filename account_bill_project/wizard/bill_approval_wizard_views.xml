<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bill_rejection_wizard_form" model="ir.ui.view">
            <field name="name">bill.rejection.wizard.form</field>
            <field name="model">bill.rejection.wizard</field>
            <field name="arch" type="xml">
                <form string="Tolak Tagihan">
                    <sheet>
                        <group>
                            <field name="move_id" readonly="1"/>
                            <field name="rejection_note"
                                   string="Alasan Penolakan"
                                   placeholder="Tuliskan alasan penolakan..."
                                   widget="text"
                                   required="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm_reject"
                                string="Konfirmasi Penolakan"
                                type="object"
                                class="btn-danger"/>
                        <button string="Batal" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
