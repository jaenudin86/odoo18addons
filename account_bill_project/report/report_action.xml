<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ═══ Report Action: Cetak Vendor Bill ═══ -->
    <record id="action_report_vendor_bill_abp" model="ir.actions.report">
        <field name="name">Tagihan Vendor</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_bill_project.report_vendor_bill</field>
        <field name="report_file">account_bill_project.report_vendor_bill</field>
        <field name="print_report_name">
            (object.name or '').replace('/', '_') + '_tagihan'
        </field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_a4"/>
    </record>

</data>
