<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- Inherit report_invoice_document - tambah project & approval info -->
<template id="report_vendor_bill_document"
          inherit_id="account.report_invoice_document">

    <!-- Tambah blok Project setelah div informations -->
    <xpath expr="//div[@id='informations']" position="after">
        <t t-if="doc.x_analytic_account_id">
            <div style="margin:4px 0 8px 0;padding:6px 12px;background:#e6f7f8;border-left:3px solid #017e84;">
                <strong style="color:#015f64;">Project: </strong>
                <span t-field="doc.x_analytic_account_id.name" style="color:#015f64;"/>
                <span style="color:#017e84;margin-left:12px;">
                    Alokasi: <t t-esc="doc.x_analytic_distribution_pct"/>%
                </span>
            </div>
        </t>
    </xpath>

    <!-- Tambah info approval setelah div total -->
    <xpath expr="//div[@id='total']" position="after">
        <t t-if="doc.x_approval_state == 'approved' and doc.x_approved_by">
            <div style="margin-top:12px;padding:8px 12px;border:1px solid #dee2e6;border-radius:4px;font-size:12px;">
                <strong>Disetujui oleh: </strong>
                <span t-field="doc.x_approved_by.name"/>
                <span style="margin-left:16px;color:#6c757d;">
                    <t t-esc="doc.x_approved_date" t-options='{"widget": "datetime"}'/>
                </span>
            </div>
        </t>
    </xpath>

</template>

<!-- Override wrapper report original vendor bill -->
<template id="report_vendor_bill"
          inherit_id="account.report_original_vendor_bill">
    <xpath expr="//div[hasclass('article')]" position="replace">
        <t t-call="account_bill_project.report_vendor_bill_document"
           t-lang="o.partner_id.lang"/>
    </xpath>
</template>

</data>
</odoo>
