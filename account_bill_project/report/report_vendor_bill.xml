<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- Inherit template vendor bill bawaan Odoo 18 -->
<!-- Base template: account.report_invoice_document -->

<template id="report_vendor_bill_document"
          inherit_id="account.report_invoice_document">

    <!-- 1. Hapus baris product (sembunyikan kolom product) -->
    <xpath expr="//td[hasclass('text-start')]" position="replace">
        <td class="text-start">
            <!-- Tampilkan COA code + name sebagai ganti product -->
            <span t-if="line.account_id"
                  t-esc="line.account_id.code + ' - ' + line.account_id.name"/>
            <span t-elif="line.name" t-esc="line.name"/>
        </td>
    </xpath>

    <!-- 2. Tambah info Project / Analytic di bawah info tagihan -->
    <xpath expr="//div[@id='informations']" position="after">
        <t t-if="doc.x_analytic_account_id">
            <div style="margin-bottom:8px;padding:6px 10px;background:#e6f7f8;border-left:3px solid #017e84;border-radius:0 4px 4px 0;">
                <strong style="color:#015f64;">Project: </strong>
                <span style="color:#015f64;" t-esc="doc.x_analytic_account_id.name"/>
                <t t-if="doc.x_analytic_account_id.code">
                    <span style="color:#017e84;"> (<t t-esc="doc.x_analytic_account_id.code"/>)</span>
                </t>
                <span style="color:#017e84;margin-left:12px;">
                    Alokasi: <t t-esc="doc.x_analytic_distribution_pct"/>%
                </span>
            </div>
        </t>
    </xpath>

    <!-- 3. Tambah status approval -->
    <xpath expr="//div[@id='informations']" position="inside">
        <t t-if="doc.x_approval_state == 'approved'">
            <div class="row mb-1">
                <div class="col-3"><strong>Disetujui Oleh</strong></div>
                <div class="col-3">
                    <span t-esc="doc.x_approved_by.name"/>
                </div>
                <div class="col-3"><strong>Tanggal</strong></div>
                <div class="col-3">
                    <span t-esc="doc.x_approved_date" t-options='{"widget": "datetime"}'/>
                </div>
            </div>
        </t>
    </xpath>

</template>

<!-- Report wrapper -->
<template id="report_vendor_bill">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="account_bill_project.report_vendor_bill_document"
               t-lang="doc.partner_id.lang"/>
        </t>
    </t>
</template>

</data>
</odoo>
