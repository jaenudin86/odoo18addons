<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="report_vendor_bill_document">
    <t t-call="web.external_layout">
        <t t-set="doc" t-value="doc"/>
        <div class="page">

            <!-- ═══ HEADER ═══ -->
            <div class="row mb-4">
                <div class="col-8">
                    <h2 class="mt-0">
                        <span t-if="doc.move_type == 'in_invoice'">TAGIHAN VENDOR</span>
                        <span t-if="doc.move_type == 'in_refund'">NOTA KREDIT VENDOR</span>
                    </h2>
                    <h3 class="text-muted mt-0" t-esc="doc.name"/>
                </div>
                <div class="col-4 text-right">
                    <!-- Status Badge -->
                    <span t-if="doc.state == 'draft'"
                          style="background:#6c757d;color:#fff;padding:4px 12px;border-radius:4px;font-size:12px;font-weight:600;">
                        DRAFT
                    </span>
                    <span t-if="doc.state == 'posted' and doc.payment_state == 'not_paid'"
                          style="background:#dc3545;color:#fff;padding:4px 12px;border-radius:4px;font-size:12px;font-weight:600;">
                        BELUM DIBAYAR
                    </span>
                    <span t-if="doc.state == 'posted' and doc.payment_state == 'in_payment'"
                          style="background:#ffc107;color:#212529;padding:4px 12px;border-radius:4px;font-size:12px;font-weight:600;">
                        SEDANG DIBAYAR
                    </span>
                    <span t-if="doc.state == 'posted' and doc.payment_state == 'paid'"
                          style="background:#28a745;color:#fff;padding:4px 12px;border-radius:4px;font-size:12px;font-weight:600;">
                        LUNAS
                    </span>
                    <!-- Approval Badge -->
                    <br/>
                    <span t-if="doc.x_approval_state == 'waiting'"
                          style="background:#ffc107;color:#212529;padding:3px 10px;border-radius:4px;font-size:11px;margin-top:4px;display:inline-block;">
                        MENUNGGU PERSETUJUAN
                    </span>
                    <span t-if="doc.x_approval_state == 'approved'"
                          style="background:#28a745;color:#fff;padding:3px 10px;border-radius:4px;font-size:11px;margin-top:4px;display:inline-block;">
                        DISETUJUI
                    </span>
                    <span t-if="doc.x_approval_state == 'rejected'"
                          style="background:#dc3545;color:#fff;padding:3px 10px;border-radius:4px;font-size:11px;margin-top:4px;display:inline-block;">
                        DITOLAK
                    </span>
                </div>
            </div>

            <!-- ═══ INFO TAGIHAN & VENDOR ═══ -->
            <div class="row mb-4">
                <!-- Vendor Info -->
                <div class="col-6">
                    <table class="table table-sm" style="border:none;">
                        <tr>
                            <td style="width:130px;color:#6c757d;border:none;padding:2px 0;">Vendor</td>
                            <td style="border:none;padding:2px 0;font-weight:600;">
                                <span t-esc="doc.partner_id.name"/>
                            </td>
                        </tr>
                        <tr t-if="doc.partner_id.street">
                            <td style="color:#6c757d;border:none;padding:2px 0;">Alamat</td>
                            <td style="border:none;padding:2px 0;">
                                <span t-esc="doc.partner_id.street"/>
                                <t t-if="doc.partner_id.city">, <span t-esc="doc.partner_id.city"/></t>
                                <t t-if="doc.partner_id.zip"> <span t-esc="doc.partner_id.zip"/></t>
                            </td>
                        </tr>
                        <tr t-if="doc.partner_id.vat">
                            <td style="color:#6c757d;border:none;padding:2px 0;">NPWP</td>
                            <td style="border:none;padding:2px 0;"><span t-esc="doc.partner_id.vat"/></td>
                        </tr>
                    </table>
                </div>

                <!-- Tanggal & Referensi -->
                <div class="col-6">
                    <table class="table table-sm" style="border:none;">
                        <tr>
                            <td style="width:130px;color:#6c757d;border:none;padding:2px 0;">No. Tagihan</td>
                            <td style="border:none;padding:2px 0;font-weight:600;"><span t-esc="doc.name"/></td>
                        </tr>
                        <tr t-if="doc.ref">
                            <td style="color:#6c757d;border:none;padding:2px 0;">No. Ref. Vendor</td>
                            <td style="border:none;padding:2px 0;"><span t-esc="doc.ref"/></td>
                        </tr>
                        <tr>
                            <td style="color:#6c757d;border:none;padding:2px 0;">Tanggal Tagihan</td>
                            <td style="border:none;padding:2px 0;">
                                <span t-esc="doc.invoice_date" t-options='{"widget": "date"}'/>
                            </td>
                        </tr>
                        <tr t-if="doc.invoice_date_due">
                            <td style="color:#6c757d;border:none;padding:2px 0;">Jatuh Tempo</td>
                            <td style="border:none;padding:2px 0;">
                                <span t-esc="doc.invoice_date_due" t-options='{"widget": "date"}'/>
                            </td>
                        </tr>
                        <tr>
                            <td style="color:#6c757d;border:none;padding:2px 0;">Jurnal</td>
                            <td style="border:none;padding:2px 0;"><span t-esc="doc.journal_id.name"/></td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- ═══ ACCOUNT ANALYTIC / PROJECT ═══ -->
            <t t-if="doc.x_analytic_account_id">
                <div class="row mb-3">
                    <div class="col-12">
                        <div style="background:#e6f7f8;border-left:4px solid #017e84;padding:8px 14px;border-radius:0 4px 4px 0;">
                            <span style="color:#015f64;font-weight:600;font-size:12px;">
                                PROJECT / ACCOUNT ANALYTIC:
                            </span>
                            <span style="color:#015f64;margin-left:8px;">
                                <t t-esc="doc.x_analytic_account_id.name"/>
                            </span>
                            <span style="color:#017e84;margin-left:16px;font-size:12px;">
                                Alokasi: <t t-esc="doc.x_analytic_distribution_pct"/>%
                            </span>
                        </div>
                    </div>
                </div>
            </t>

            <!-- ═══ TABEL BARIS COA ═══ -->
            <table class="table table-sm table-bordered mt-2" style="font-size:12px;">
                <thead>
                    <tr style="background:#f8f9fa;">
                        <th style="width:5%;text-align:center;">#</th>
                        <th style="width:20%;">Akun COA</th>
                        <th style="width:30%;">Keterangan</th>
                        <th style="width:15%;">Analytic</th>
                        <th style="width:8%;text-align:right;">Qty</th>
                        <th style="width:12%;text-align:right;">Harga</th>
                        <th style="width:10%;text-align:right;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="doc.invoice_line_ids" t-as="line">
                        <t t-if="line.display_type == 'product'">
                            <tr>
                                <td style="text-align:center;color:#6c757d;">
                                    <t t-esc="line_index + 1"/>
                                </td>
                                <td>
                                    <strong t-esc="line.account_id.code"/>
                                    <br/>
                                    <small class="text-muted" t-esc="line.account_id.name"/>
                                </td>
                                <td>
                                    <span t-esc="line.name"/>
                                </td>
                                <td style="font-size:11px;">
                                    <t t-if="doc.x_analytic_account_id">
                                        <span style="background:#e6f7f8;color:#015f64;padding:1px 6px;border-radius:3px;">
                                            <t t-esc="doc.x_analytic_account_id.code or doc.x_analytic_account_id.name"/>
                                            · <t t-esc="doc.x_analytic_distribution_pct"/>%
                                        </span>
                                    </t>
                                </td>
                                <td style="text-align:right;">
                                    <t t-esc="line.quantity"/>
                                </td>
                                <td style="text-align:right;">
                                    <t t-esc="line.price_unit"
                                       t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                                <td style="text-align:right;font-weight:500;">
                                    <t t-esc="line.price_subtotal"
                                       t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                        </t>
                    </t>
                </tbody>
            </table>

            <!-- ═══ TOTAL ═══ -->
            <div class="row">
                <div class="col-6">
                    <!-- Terbilang placeholder -->
                    <t t-if="doc.amount_total">
                        <div style="border:1px solid #dee2e6;border-radius:4px;padding:8px 12px;font-size:11px;color:#495057;">
                            <strong>Terbilang:</strong><br/>
                            <em style="color:#6c757d;">
                                <!-- terbilang di-generate dari amount_total -->
                                <t t-esc="doc.currency_id.name"/>
                                <t t-esc="'{:,.0f}'.format(doc.amount_total)"/>
                            </em>
                        </div>
                    </t>
                </div>
                <div class="col-6">
                    <table class="table table-sm" style="border:none;">
                        <tr>
                            <td style="border:none;color:#6c757d;">Subtotal</td>
                            <td style="border:none;text-align:right;">
                                <t t-esc="doc.amount_untaxed"
                                   t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                            </td>
                        </tr>
                        <t t-foreach="doc.amount_by_group" t-as="tax_group">
                            <tr>
                                <td style="border:none;color:#6c757d;">
                                    <t t-esc="tax_group[0]"/>
                                </td>
                                <td style="border:none;text-align:right;">
                                    <t t-esc="tax_group[1]"
                                       t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                        </t>
                        <tr style="border-top:2px solid #212529;">
                            <td style="border:none;font-weight:700;font-size:14px;">TOTAL</td>
                            <td style="border:none;text-align:right;font-weight:700;font-size:14px;color:#017e84;">
                                <t t-esc="doc.amount_total"
                                   t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                            </td>
                        </tr>
                        <t t-if="doc.amount_residual and doc.state == 'posted'">
                            <tr>
                                <td style="border:none;color:#dc3545;">Sisa Tagihan</td>
                                <td style="border:none;text-align:right;color:#dc3545;font-weight:600;">
                                    <t t-esc="doc.amount_residual"
                                       t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                        </t>
                    </table>
                </div>
            </div>

            <!-- ═══ APPROVAL INFO ═══ -->
            <t t-if="doc.x_approval_state in ['approved', 'rejected']">
                <div class="row mt-4">
                    <div class="col-12">
                        <div style="border:1px solid #dee2e6;border-radius:4px;padding:10px 14px;font-size:12px;">
                            <strong>INFO PERSETUJUAN</strong>
                            <table style="width:100%;margin-top:6px;border:none;">
                                <tr t-if="doc.x_approved_by">
                                    <td style="color:#6c757d;width:160px;border:none;padding:2px 0;">Disetujui Oleh</td>
                                    <td style="border:none;padding:2px 0;font-weight:600;">
                                        <t t-esc="doc.x_approved_by.name"/>
                                    </td>
                                    <td style="color:#6c757d;width:120px;border:none;padding:2px 0;">Tanggal</td>
                                    <td style="border:none;padding:2px 0;">
                                        <t t-esc="doc.x_approved_date" t-options='{"widget": "datetime"}'/>
                                    </td>
                                </tr>
                                <tr t-if="doc.x_rejected_reason">
                                    <td style="color:#dc3545;border:none;padding:2px 0;">Alasan Penolakan</td>
                                    <td colspan="3" style="border:none;padding:2px 0;">
                                        <t t-esc="doc.x_rejected_reason"/>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </t>

            <!-- ═══ TANDA TANGAN ═══ -->
            <div class="row mt-5">
                <div class="col-4 text-center">
                    <div style="border-top:1px solid #212529;margin-top:50px;padding-top:6px;font-size:12px;">
                        Dibuat Oleh
                    </div>
                </div>
                <div class="col-4 text-center">
                    <div style="border-top:1px solid #212529;margin-top:50px;padding-top:6px;font-size:12px;">
                        Diperiksa Oleh
                    </div>
                </div>
                <div class="col-4 text-center">
                    <div style="border-top:1px solid #212529;margin-top:50px;padding-top:6px;font-size:12px;">
                        Disetujui Oleh
                        <t t-if="doc.x_approved_by">
                            <br/><strong t-esc="doc.x_approved_by.name"/>
                        </t>
                    </div>
                </div>
            </div>

        </div>
    </t>
</template>

<!-- ═══ REPORT ACTION ═══ -->
<template id="report_vendor_bill">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="account_bill_project.report_vendor_bill_document"
               t-lang="doc.partner_id.lang"/>
        </t>
    </t>
</template>

</data>
</odoo>
