<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         Inherit res.users form – add approval checkboxes in the
         "Access Rights" tab, under the Inventory section.
    ══════════════════════════════════════════════════════════════════ -->
    <record id="view_users_form_approval" model="ir.ui.view">
        <field name="name">res.users.form.approval</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <!-- Find the "Access Rights" page and append our group -->
            <xpath expr="//page[@name='access_rights']" position="inside">
                <group string="Internal Transfer Approval" name="internal_transfer_approval_group">
                    <field
                        name="is_internal_transfer_creator"
                        widget="boolean_toggle"
                        string="Can Create Internal Transfers (with Approval)"
                        help="This user can create internal transfers that require approval."
                    />
                    <field
                        name="is_internal_transfer_approver"
                        widget="boolean_toggle"
                        string="Can Approve Internal Transfers"
                        help="This user can approve or refuse internal transfers created by others."
                    />
                </group>
            </xpath>

        </field>
    </record>

</odoo>
