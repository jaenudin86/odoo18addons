<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ══════════════════════════════════════════════════════════
             Category
        ══════════════════════════════════════════════════════════ -->
        <record id="module_category_stock_internal_approval"
                model="ir.module.category">
            <field name="name">Inventory / Internal Transfer Approval</field>
            <field name="description">
                Manage access rights for the internal transfer approval workflow.
            </field>
            <field name="sequence">10</field>
        </record>

        <!-- ══════════════════════════════════════════════════════════
             Groups
        ══════════════════════════════════════════════════════════ -->

        <!-- Group: Transfer Creator -->
        <record id="group_internal_transfer_creator"
                model="res.groups">
            <field name="name">Internal Transfer Creator</field>
            <field name="category_id"
                   ref="module_category_stock_internal_approval"/>
            <field name="comment">
                Users in this group can create internal transfers that require approval.
            </field>
        </record>

        <!-- Group: Transfer Approver -->
        <record id="group_internal_transfer_approver"
                model="res.groups">
            <field name="name">Internal Transfer Approver</field>
            <field name="category_id"
                   ref="module_category_stock_internal_approval"/>
            <field name="comment">
                Users in this group can approve or refuse internal transfers
                created by other users.
            </field>
        </record>

    </data>
</odoo>
