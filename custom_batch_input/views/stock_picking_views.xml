<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- Tambah tombol wizard di Receipt -->
    <record id="view_stock_picking_form_batch_input" model="ir.ui.view">
        <field name="name">stock.picking.form.batch.input</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_open_batch_input_wizard"
                    string="Input Batch &amp; Expired"
                    type="object"
                    class="btn-secondary"
                    invisible="picking_type_code != 'incoming' or state in ('done', 'cancel')"/>
            </header>
        </field>
    </record>

</odoo>
