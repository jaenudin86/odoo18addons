<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Stock Quant List View (Inventory Report) -->
    <record id="view_stock_quant_tree_inventory_editable_inherit_batch" model="ir.ui.view">
        <field name="name">stock.quant.inventory.tree.inherit.batch</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="x_batch_number" optional="show"/>
                <field name="expiration_date" optional="show" widget="date"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_quant_tree_editable_inherit_batch" model="ir.ui.view">
        <field name="name">stock.quant.tree.inherit.batch</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="x_batch_number" optional="show"/>
                <field name="expiration_date" optional="show" widget="date"/>
            </xpath>
        </field>
    </record>
</odoo>
