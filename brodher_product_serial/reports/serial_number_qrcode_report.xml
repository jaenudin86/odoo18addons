<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Action -->
    <record id="action_report_serial_number_qrcode" model="ir.actions.report">
        <field name="name">Serial Number QR Labels</field>
        <field name="model">stock.lot</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">brodher_product_serial.serial_number_qrcode_template</field>
        <field name="report_file">brodher_product_serial.serial_number_qrcode_template</field>
        <field name="binding_model_id" ref="stock.model_stock_lot"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="brodher_product_serial.paperformat_product_qrcode_label_a4"/>
    </record>

    <!-- Report Template -->
    <template id="serial_number_qrcode_template">
        <t t-call="web.basic_layout">
            <div class="page" style="padding: 0; margin: 0;">
                <style>
                    @page {
                        size: 15mm 20mm;
                        margin: 0;
                    }
                    html, body {
                        margin: 0 !important;
                        padding: 0 !important;
                        width: 15mm;
                        height: 20mm;
                    }
                    .page {
                        padding: 0 !important;
                        margin: 0 !important;
                    }
                    .label-wrap {
                        width: 15mm;
                        height: 20mm;
                        overflow: hidden;
                        box-sizing: border-box;
                        padding: 0.5mm;
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        page-break-after: always;
                    }
                    .label-wrap:last-child {
                        page-break-after: auto;
                    }
                    .label-text {
                        display: block;
                        font-size: 4.5pt;
                        line-height: 1.2;
                        word-break: break-word;
                        max-width: 100%;
                        text-align: center;
                    }
                    .label-ir {
                        font-weight: bold;
                        font-size: 4pt;
                    }
                    .label-name {
                        font-weight: bold;
                        font-size: 4.5pt;
                    }
                    .label-variant {
                        font-size: 4pt;
                        color: #444;
                    }
                    .qrcode_img {
                        width: 11mm;
                        height: 11mm;
                        display: block;
                        margin: 0.3mm auto;
                    }
                    .label-sn {
                        display: block;
                        font-weight: bold;
                        font-size: 4.5pt;
                        margin-top: 0.2mm;
                        word-break: break-all;
                        text-align: center;
                    }
                </style>

                <t t-if="not docs">
                    <div style="text-align: center; padding: 5mm; color: #999;">
                        <p>No Serial Numbers Selected</p>
                    </div>
                </t>

                <t t-if="docs">
                    <t t-foreach="docs" t-as="sn">
                        <div class="label-wrap">
                            <!-- IR Number (Internal Reference) -->
                            <span class="label-text label-ir">
                                <t t-esc="sn.product_id.default_code or '-'"/>
                            </span>
                            <!-- Product Name -->
                            <span class="label-text label-name">
                                <t t-esc="sn.product_id.product_tmpl_id.name"/>
                            </span>
                            <!-- Variant -->
                            <t t-set="variant_vals" t-value="sn.product_id.product_template_attribute_value_ids.mapped('product_attribute_value_id.name')"/>
                            <span t-if="variant_vals" class="label-text label-variant">
                                <t t-esc="', '.join(variant_vals)"/>
                            </span>
                            <!-- QR Code -->
                            <img t-att-src="'/report/barcode/QR/%s' % sn.name"
                                class="qrcode_img"
                                alt="QR"/>
                            <!-- Serial Number -->
                            <span class="label-sn">
                                <t t-esc="sn.name"/>
                            </span>
                        </div>
                    </t>
                </t>

            </div>
        </t>
    </template>
</odoo>