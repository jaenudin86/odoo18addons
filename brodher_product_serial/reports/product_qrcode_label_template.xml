<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="product_qrcode_label_template">
        <t t-call="web.basic_layout">
            <div class="page" style="padding: 0; margin: 0;">
                <style>
                    @page {
                        size: 15mm 20mm;
                        margin: 0;
                    }
                    html, body {
                        margin: 0 !important;
                        padding: 0 !important;
                        width: 15mm;
                        height: 20mm;
                    }
                    .page {
                        padding: 0 !important;
                        margin: 0 !important;
                    }
                    .label-wrapper {
                        width: 15mm;
                        height: 20mm;
                        padding: 0.5mm;
                        box-sizing: border-box;
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        overflow: hidden;
                        page-break-after: always;
                    }
                    .label-wrapper:last-child {
                        page-break-after: auto;
                    }
                    .qrcode_img {
                        width: 11mm;
                        height: 11mm;
                        display: block;
                        margin: 0 auto;
                    }
                    .label-text {
                        font-size: 4.5pt;
                        line-height: 1.2;
                        text-align: center;
                        word-break: break-all;
                        margin-top: 0.5mm;
                        width: 100%;
                    }
                </style>

                <t t-foreach="label_data" t-as="label">
                    <div class="label-wrapper">
                        <img t-if="label['barcode']"
                             t-att-src="'/report/barcode/QR/%s' % label['barcode']"
                             class="qrcode_img"
                             alt="QR"/>
                        <div t-else="" style="width:11mm;height:11mm;border:0.2mm dashed #ccc;"/>
                        <div class="label-text">
                            <t t-esc="label['name']"/><br/>
                            <t t-if="label['variant']"><t t-esc="label['variant']"/><br/></t>
                            <t t-esc="label['barcode']"/>
                        </div>
                    </div>
                </t>

            </div>
        </t>
    </template>
</odoo>
