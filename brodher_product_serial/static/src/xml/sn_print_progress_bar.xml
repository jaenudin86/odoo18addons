<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="brodher_product_serial.SNPrintProgressBar">
        <div class="o_sn_print_progress_container d-flex flex-column align-items-center justify-content-center p-5">
            <h3 class="mb-4 text-primary">Menyiapkan Label QR Code</h3>
            
            <div class="progress w-100" style="height: 30px; border-radius: 15px; overflow: hidden; background-color: #e9ecef; box-shadow: inset 0 1px 3px rgba(0,0,0,.1);">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" 
                     role="progressbar" 
                     t-att-style="'width: ' + state.progress + '%; transition: width 0.3s ease;'" 
                     t-att-aria-valuenow="state.progress" 
                     aria-valuemin="0" 
                     aria-valuemax="100">
                    <t t-esc="Math.round(state.progress)"/>%
                </div>
            </div>
            
            <p class="mt-3 text-muted">
                <i class="fa fa-cog fa-spin me-2" t-if="!state.isFinished"/>
                <t t-esc="state.statusText"/>
            </p>

            <div class="alert alert-info mt-4 w-100" t-if="!state.isFinished">
                <i class="fa fa-info-circle me-2"/> 
                Jangan tutup jendela ini sampai proses download dimulai otomatis.
            </div>
        </div>
    </t>
</templates>
