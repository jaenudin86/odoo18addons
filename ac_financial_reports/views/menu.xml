<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client Actions -->
    <record id="action_trial_balance" model="ir.actions.client">
        <field name="name">Trial Balance</field>
        <field name="tag">ac_financial_reports.trial_balance</field>
    </record>
    <record id="action_profit_loss" model="ir.actions.client">
        <field name="name">Profit &amp; Loss</field>
        <field name="tag">ac_financial_reports.profit_loss</field>
    </record>
    <record id="action_balance_sheet" model="ir.actions.client">
        <field name="name">Balance Sheet</field>
        <field name="tag">ac_financial_reports.balance_sheet</field>
    </record>
    <record id="action_general_ledger" model="ir.actions.client">
        <field name="name">General Ledger</field>
        <field name="tag">ac_financial_reports.general_ledger</field>
    </record>
    <record id="action_cash_flow" model="ir.actions.client">
        <field name="name">Cash Flow Statement</field>
        <field name="tag">ac_financial_reports.cash_flow</field>
    </record>
    <record id="action_aging_report" model="ir.actions.client">
        <field name="name">Aging Report</field>
        <field name="tag">ac_financial_reports.aging_report</field>
    </record>

    <!-- Menu: Accounting > Reporting > Financial Reports -->
    <menuitem id="menu_financial_reports_root"
              name="Financial Reports"
              parent="account.menu_finance_reports"
              sequence="1"/>

    <menuitem id="menu_trial_balance"
              name="Trial Balance"
              parent="menu_financial_reports_root"
              action="action_trial_balance"
              sequence="10"/>

    <menuitem id="menu_profit_loss"
              name="Profit &amp; Loss"
              parent="menu_financial_reports_root"
              action="action_profit_loss"
              sequence="20"/>

    <menuitem id="menu_balance_sheet"
              name="Balance Sheet"
              parent="menu_financial_reports_root"
              action="action_balance_sheet"
              sequence="30"/>

    <menuitem id="menu_general_ledger"
              name="General Ledger"
              parent="menu_financial_reports_root"
              action="action_general_ledger"
              sequence="40"/>

    <menuitem id="menu_cash_flow"
              name="Cash Flow Statement"
              parent="menu_financial_reports_root"
              action="action_cash_flow"
              sequence="50"/>

    <menuitem id="menu_aging_report"
              name="Aging Report"
              parent="menu_financial_reports_root"
              action="action_aging_report"
              sequence="60"/>

</odoo>
