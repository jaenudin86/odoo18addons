<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <!--
        Enforce mandatory rounding on common currencies shipped with Odoo.
        noupdate="0" ensures these are RE-APPLIED every time the module is updated.

        Policy:
          - IDR  = 0.01   (2 decimal places)
          - All others = 0.001 (3 decimal places)

        Note: The Python ORM layer (res_currency.py) enforces this for ALL currencies
        including ones not listed here. This XML handles the most common ones
        declaratively and ensures the DB is correct from the start.
    -->

    <!-- ── IDR: 2 decimal places ─────────────────────────────────────────── -->
    <record id="base.IDR" model="res.currency">
        <field name="rounding">0.01</field>
        <field name="decimal_places">2</field>
    </record>

    <!-- ── Major currencies: 3 decimal places ────────────────────────────── -->
    <record id="base.USD" model="res.currency">
        <field name="rounding">0.001</field>
        <field name="decimal_places">3</field>
    </record>

    <record id="base.EUR" model="res.currency">
        <field name="rounding">0.001</field>
        <field name="decimal_places">3</field>
